# AMADA v6.0 Environment — copy to .env and fill values
# Fix #23: .env is listed in .gitignore — never commit real keys
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
AUDIT_DIR=./audit_logs
MODEL_CACHE_DIR=./model_cache

# Encrypted API keys (use: python -m hallucination_guard.security.key_manager encrypt KEY value)
ANTHROPIC_API_KEY_ENC=
GOOGLE_SEARCH_API_KEY_ENC=
GOOGLE_SEARCH_ENGINE_ID=
GEMINI_API_KEY_ENC=

# Raw keys (dev only — never commit real values, use _ENC variants for production)
# Judge priority: Claude → Gemini → local fallback
# Get Gemini key free at: https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=
GOOGLE_SEARCH_API_KEY=
GEMINI_API_KEY=
